pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    triggers {
        // Push-based: requires GitHub plugin + webhook in repo settings pointing to
        // http://<jenkins-host>:8080/github-webhook/
        githubPush()

        // Fallback polling every 2 min in case the webhook is not reachable
        pollSCM('H/2 * * * *')
    }

    environment {
        BACKEND_IMAGE  = 'hobbiz-backend'
        FRONTEND_IMAGE = 'hobbiz-frontend'
        MDSSC_API_KEY  = credentials('mdssc-api-key')  // Secret Text credential in Jenkins
        MDSSC_API_URL  = credentials('mdssc-api-url')  // Secret Text credential in Jenkins
        // MDSSC_WORKFLOW_ID  = ''        // optional: pin to a specific MDSSC workflow
        // MDSSC_FAIL_ON_HIGH = 'false'   // set 'true' to also fail on high-severity vulns
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ── Stage 1: Source-code scan (MDSSC) ────────────────────────────────
        stage('Scan Source Code') {
            steps {
                sh 'chmod +x ci/mdssc/scan-source.sh'
                sh 'ci/mdssc/scan-source.sh'
            }
        }

        // ── Stage 2: Build artifacts ──────────────────────────────────────────
        stage('Build Backend') {
            steps {
                dir('backend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                    // Mărim heap-ul Node ca să evităm OOM în timpul vite build pe agenți mici
                    sh 'NODE_OPTIONS="--max-old-space-size=4096" npm run build'
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'frontend/dist/**/*', fingerprint: true
            }
        }

        // ── Stage 3: Artifact scan (MDSSC) ───────────────────────────────────
        stage('Scan Artifacts') {
            steps {
                sh 'chmod +x ci/mdssc/scan-artifacts.sh'
                sh 'ci/mdssc/scan-artifacts.sh'
            }
        }

        stage('Build Docker Images') {
            steps {
                sh "docker build -t ${BACKEND_IMAGE}:${BUILD_NUMBER} ./backend"
                sh "docker build -t ${FRONTEND_IMAGE}:${BUILD_NUMBER} ./frontend"
            }
        }

        // ── Stage 4: Deploy ───────────────────────────────────────────────────
        stage('Deploy') {
            steps {
                withCredentials([file(credentialsId: 'backend-env-file', variable: 'BACKEND_ENV')]) {
                    sh '''
                        chmod 755 backend
                        rm -f backend/.env
                        cp "$BACKEND_ENV" backend/.env
                    '''
                }
                sh 'docker rm -f hobbiz_mongo hobbiz_backend hobbiz_frontend || true'
                sh 'docker-compose down --remove-orphans || true'
                sh 'docker-compose up -d --build'
            }
        }
    }

    post {
        success {
            echo "Build #${BUILD_NUMBER} deployed successfully."
        }
        failure {
            echo "Build #${BUILD_NUMBER} failed. Check the logs above."
        }
        always {
            echo 'Pipeline finished.'
            sh """
                docker images '${BACKEND_IMAGE}' --format '{{.Tag}}' \
                    | sort -rn | tail -n +4 \
                    | xargs -I{} docker rmi ${BACKEND_IMAGE}:{} || true
                docker images '${FRONTEND_IMAGE}' --format '{{.Tag}}' \
                    | sort -rn | tail -n +4 \
                    | xargs -I{} docker rmi ${FRONTEND_IMAGE}:{} || true
                docker image prune -f || true
            """
        }
    }
}
