{
  "name": "hobbiz-mui-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:backend",
    "build:backend": "cd backend && npm install --production",
    "start": "cd backend && npm start",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "overrides": {
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.4",
    "brace-expansion": "5.0.6",
    "node-forge": "1.4.0",
    "yaml": "2.8.3",
    "minimatch": ">=10.2.2",
    "qs": ">=6.15.2",
    "shell-quote": ">=1.8.4",
    "ws": ">=8.21.0",
    "uuid": "11.1.1",
    "js-yaml": "4.2.0",
    "@babel/core": ">=7.29.7"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^11.4.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mailersend": "^2.6.0",
    "motion": "^12.38.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "docx": "^9.6.1"
  }
}
